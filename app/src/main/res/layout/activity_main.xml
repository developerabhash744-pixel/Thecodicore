<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/vscode_bg">

    <!-- 1. Top Bar (Full Width at the very top) -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="@color/vscode_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <!-- Logo on the top left corner -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="App Logo" />

        <!-- Spacer to push options to the right -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Top Bar Title/Menu Mockup (shifted to the right) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="File   Edit   Selection   View   Go   Run   Terminal   Help"
            android:textColor="@color/vscode_text_secondary"
            android:textSize="12sp"
            android:layout_marginEnd="20dp" />

        <!-- Mock Window Controls -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" ⚊   🗖   ✕ "
            android:textColor="@color/vscode_text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Divider below Top Bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/vscode_card_stroke" />

    <!-- 2. Bottom Area: Left Activity Bar + Main Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left Activity Bar (starts below top bar) -->
        <LinearLayout
            android:id="@+id/activity_bar"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:background="@color/vscode_sidebar"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingVertical="10dp">

            <!-- Explorer Icon -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_explorer"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:background="@color/vscode_bg"
                android:contentDescription="Explorer" />

            <!-- Search Icon -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_search"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:contentDescription="Search" />

            <!-- Source Control Icon -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_source_control"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:contentDescription="Source Control" />

            <!-- Run/Debug Icon -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_debug"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:contentDescription="Run and Debug" />

            <!-- Extensions Icon -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_extensions"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:contentDescription="Extensions" />

            <!-- Spacer to push settings to the bottom -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Profile Icon -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_account"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:contentDescription="Profile" />

            <!-- Settings Icon -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_settings"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:contentDescription="Settings" />
        </LinearLayout>

        <!-- Vertical Divider between Activity Bar and Main Content -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/vscode_card_stroke" />

        <!-- Main Content Panel containing Monaco Editor WebView -->
        <FrameLayout
            android:id="@+id/content_area"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/vscode_bg">

            <WebView
                android:id="@+id/monaco_webview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/vscode_bg" />
        </FrameLayout>
    </LinearLayout>

    <!-- 3. Bottom Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:background="@color/vscode_status_bar"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌿 main"
            android:textColor="@android:color/white"
            android:textSize="10sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UTF-8   Kotlin   0 ⓧ  0 ⚠"
            android:textColor="@android:color/white"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>
