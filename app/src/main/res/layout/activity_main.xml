<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/vscode_bg">

    <!-- 1. Top Bar (Full Width at the very top) -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="@color/vscode_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <!-- Logo on the top left corner -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="App Logo" />

        <!-- Spacer to push options to the right -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Top Bar Title/Menu Mockup (shifted to the right) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="File      Edit      Selection      View      Go      Run      Terminal      Help"
            android:textColor="@color/vscode_text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Divider below Top Bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/vscode_card_stroke" />

    <!-- 2. Bottom Area: Left Activity Bar + Main Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left Activity Bar (starts below top bar) -->
        <LinearLayout
            android:id="@+id/activity_bar"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:background="@color/vscode_sidebar"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingVertical="10dp">

            <!-- Explorer Icon -->
            <ImageView
                android:id="@+id/icon_explorer"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_explorer"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:background="@color/vscode_bg"
                android:contentDescription="Explorer" />

            <!-- Search Icon -->
            <ImageView
                android:id="@+id/icon_search"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_search"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:contentDescription="Search" />

            <!-- Source Control Icon -->
            <ImageView
                android:id="@+id/icon_source_control"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_source_control"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:contentDescription="Source Control" />

            <!-- Run/Debug Icon -->
            <ImageView
                android:id="@+id/icon_debug"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_debug"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:contentDescription="Run and Debug" />

            <!-- Extensions Icon -->
            <ImageView
                android:id="@+id/icon_extensions"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_extensions"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:contentDescription="Extensions" />

            <!-- Spacer to push settings to the bottom -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Profile Icon -->
            <ImageView
                android:id="@+id/icon_account"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_account"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:contentDescription="Profile" />

            <!-- Settings Icon -->
            <ImageView
                android:id="@+id/icon_settings"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/ic_settings"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:contentDescription="Settings" />
        </LinearLayout>

        <!-- Collapsible Side Panel (VS Code style) -->
        <LinearLayout
            android:id="@+id/sidebar_panel"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:background="@color/vscode_sidebar"
            android:orientation="vertical"
            android:visibility="visible"
            android:padding="12dp">

            <!-- Sidebar Title -->
            <TextView
                android:id="@+id/sidebar_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EXPLORER"
                android:textColor="@color/vscode_text_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="12dp" />

            <!-- Sidebar Content Container -->
            <FrameLayout
                android:id="@+id/sidebar_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Explorer Content (Default) -->
                <LinearLayout
                    android:id="@+id/content_explorer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="▼ THECODICORE"
                        android:textColor="@color/vscode_text_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="  📁 app"
                        android:textColor="@color/vscode_text_primary"
                        android:textSize="12sp"
                        android:paddingVertical="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="    📁 src"
                        android:textColor="@color/vscode_text_secondary"
                        android:textSize="12sp"
                        android:paddingVertical="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="      📄 MainActivity.java"
                        android:textColor="@color/vscode_link"
                        android:textSize="12sp"
                        android:paddingVertical="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="  📄 build.gradle"
                        android:textColor="@color/vscode_text_secondary"
                        android:textSize="12sp"
                        android:paddingVertical="4dp" />
                </LinearLayout>

                <!-- Search Content -->
                <LinearLayout
                    android:id="@+id/content_search"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Search"
                        android:textColorHint="@color/vscode_text_secondary"
                        android:textColor="@color/vscode_text_primary"
                        android:background="@color/vscode_card_bg"
                        android:padding="6dp"
                        android:textSize="12sp"
                        android:maxLines="1" />
                </LinearLayout>

                <!-- Source Control Content -->
                <LinearLayout
                    android:id="@+id/content_source_control"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Source Control: Git"
                        android:textColor="@color/vscode_text_secondary"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✔ MainActivity.java [M]"
                        android:textColor="@color/vscode_text_primary"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- Debug Content -->
                <LinearLayout
                    android:id="@+id/content_debug"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Button
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Run and Debug"
                        android:textSize="12sp"
                        android:backgroundTint="@color/vscode_status_bar"
                        android:textColor="@android:color/white" />
                </LinearLayout>

                <!-- Extensions Content -->
                <LinearLayout
                    android:id="@+id/content_extensions"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="RECOMMENDED"
                        android:textColor="@color/vscode_text_secondary"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Kotlin Support (v1.9)"
                        android:textColor="@color/vscode_text_primary"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Java Debugger (v0.5)"
                        android:textColor="@color/vscode_text_primary"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Account Content -->
                <LinearLayout
                    android:id="@+id/content_account"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Signed in as:"
                        android:textColor="@color/vscode_text_secondary"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="developerabhash744-pixel"
                        android:textColor="@color/vscode_text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Settings Content -->
                <LinearLayout
                    android:id="@+id/content_settings"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Settings"
                        android:textColor="@color/vscode_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enable Autocomplete"
                        android:textColor="@color/vscode_text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

        <!-- Vertical Divider between Sidebar Panel and Main Content -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/vscode_card_stroke" />

        <!-- Main Content Panel containing Monaco Editor WebView -->
        <FrameLayout
            android:id="@+id/content_area"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/vscode_bg">

            <WebView
                android:id="@+id/monaco_webview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/vscode_bg" />
        </FrameLayout>
    </LinearLayout>

    <!-- 3. Bottom Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:background="@color/vscode_status_bar"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌿 main"
            android:textColor="@android:color/white"
            android:textSize="10sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UTF-8   Kotlin   0 ⓧ  0 ⚠"
            android:textColor="@android:color/white"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>
